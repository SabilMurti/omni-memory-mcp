    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^22.5.0",
    "typescript": "^5.5.4",
    "nodemon": "^3.1.4",
    "vite": "^5.4.2"
  }
}
