{
  "name": "omni-memory-mcp",
  "version": "1.0.0",
  "description": "Single Source of Truth Memory System for AI Agents with Web Dashboard",
  "main": "dist/index.js",
  "bin": {
    "omni-memory": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
